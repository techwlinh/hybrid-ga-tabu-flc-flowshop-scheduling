<mxfile host="Electron" agent="5.0"><diagram id="diagram_2" name="System Architecture &amp; Flow Logic"><mxGraphModel dx="1035" dy="573" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1654" pageHeight="1200" background="#FFFFFF" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="2" parent="1" value="&lt;b&gt;&lt;font size='5' color='#1B365D'&gt;SMT SCHEDULING SYSTEM (HFGA-TS) ARCHITECTURE &amp; DATA FLOW&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;b&gt;&lt;font size='3' color='#4A5568'&gt;Interactive Visual Specification for Data Model, Flow Logic, and Algorithm Mechanics&lt;/font&gt;&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1"><mxGeometry x="50" y="20" width="1550" height="60" as="geometry" /></mxCell><mxCell id="3" parent="1" value="&lt;b&gt;SMT DOMAIN DATA MODEL &amp; ENTITIES&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#E2E8F0;strokeWidth=2;align=center;verticalAlign=top;fontColor=#1B365D;fontStyle=1;fontSize=13;spacingTop=10;" vertex="1"><mxGeometry x="50" y="100" width="480" height="1050" as="geometry" /></mxCell><mxCell id="4" parent="1" value="&lt;b&gt;HFGA-TS ALGORITHM FLOW &amp; OPTIMIZATION LOGIC&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#E2E8F0;strokeWidth=2;align=center;verticalAlign=top;fontColor=#1B365D;fontStyle=1;fontSize=13;spacingTop=10;" vertex="1"><mxGeometry x="550" y="100" width="560" height="1050" as="geometry" /></mxCell><mxCell id="5" parent="1" value="&lt;b&gt;INTERACTIVE PLAYGROUND &amp; EXPLAINABLE RESULTS&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#E2E8F0;strokeWidth=2;align=center;verticalAlign=top;fontColor=#1B365D;fontStyle=1;fontSize=13;spacingTop=10;" vertex="1"><mxGeometry x="1130" y="100" width="470" height="1050" as="geometry" /></mxCell><mxCell id="10" parent="1" value="&lt;b&gt;Table: Job&lt;/b&gt;&lt;br/&gt;• id: int (PK)&lt;br/&gt;• quantity (Q_j): int&lt;br/&gt;• priority: int (1, 2, 3)&lt;br/&gt;• due_date (D_j): float&lt;br/&gt;• material_arrival (s_j): float&lt;br/&gt;• unit_processing_times: array[M]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B365D;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="80" y="150" width="200" height="110" as="geometry" /></mxCell><mxCell id="11" parent="1" value="&lt;b&gt;Table: Batch&lt;/b&gt;&lt;br/&gt;• id: str (PK)&lt;br/&gt;• job_id: int (FK)&lt;br/&gt;• batch_index: int&lt;br/&gt;• quantity (q_jk): float&lt;br/&gt;• processing_times: array[M]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B365D;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="80" y="310" width="200" height="95" as="geometry" /></mxCell><mxCell id="12" parent="1" value="&lt;b&gt;Table: Workstation&lt;/b&gt;&lt;br/&gt;• id: int (PK)&lt;br/&gt;• name: str&lt;br/&gt;• num_machines (m_w): int" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B365D;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="300" y="150" width="200" height="70" as="geometry" /></mxCell><mxCell id="13" parent="1" value="&lt;b&gt;Table: Machine&lt;/b&gt;&lt;br/&gt;• id: int (PK)&lt;br/&gt;• workstation_id: int (FK)&lt;br/&gt;• name: str" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B365D;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="300" y="270" width="200" height="70" as="geometry" /></mxCell><mxCell id="14" parent="1" value="&lt;b&gt;Table: Setup Matrix&lt;/b&gt;&lt;br/&gt;• workstation_id: int (FK)&lt;br/&gt;• from_job_id: int (FK)&lt;br/&gt;• to_job_id: int (FK)&lt;br/&gt;• setup_time: float&lt;br/&gt;• setup_cost: float" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B365D;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="80" y="460" width="200" height="95" as="geometry" /></mxCell><mxCell id="15" parent="1" value="&lt;b&gt;Table: Transport Time&lt;/b&gt;&lt;br/&gt;• from_ws: int (FK)&lt;br/&gt;• to_ws: int (FK)&lt;br/&gt;• transport_time (TT_w): float" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1B365D;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="300" y="390" width="200" height="70" as="geometry" /></mxCell><mxCell id="16" parent="1" value="&lt;b&gt;Table: Schedule Result Entry&lt;/b&gt;&lt;br/&gt;• batch_id: str (FK)&lt;br/&gt;• job_id: int (FK)&lt;br/&gt;• workstation_id: int (FK)&lt;br/&gt;• machine_id: int (FK)&lt;br/&gt;• start_time: float&lt;br/&gt;• end_time: float&lt;br/&gt;• setup_time: float&lt;br/&gt;• setup_cost: float&lt;br/&gt;• waiting_time (transit/material): float" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;strokeWidth=2;align=left;spacingLeft=8;fontSize=11;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="190" y="600" width="220" height="150" as="geometry" /></mxCell><mxCell id="100" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B365D;strokeWidth=1.5;fillColor=none;value=1:N;" edge="1" source="10" target="11" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="101" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B365D;strokeWidth=1.5;fillColor=none;value=1:N;" edge="1" source="12" target="13" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="102" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;strokeWidth=1.5;fillColor=none;value=1:N;" edge="1" source="11" target="16" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="103" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#16A34A;strokeWidth=1.5;fillColor=none;value=1:N;" edge="1" source="13" target="16" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="104" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B365D;strokeWidth=1.5;strokeDasharray=3;fillColor=none;value=influences;" edge="1" source="14" target="16" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="105" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#1B365D;strokeWidth=1.5;strokeDasharray=3;fillColor=none;value=constrains;" edge="1" source="15" target="16" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="17" parent="1" value="&lt;b&gt;Chromosome Encoding (Random Key)&lt;/b&gt;&lt;br/&gt;• Size: 2 × N_batches&lt;br/&gt;┌────────────────────┬────────────────────┐&lt;br/&gt;│    Job Sequence    │ Machine Assignment │&lt;br/&gt;│  [0, 1] Real Value │  [0, 1] Real Value │&lt;br/&gt;└────────────────────┴────────────────────┘" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F3FF;strokeColor=#7C3AED;strokeWidth=2;align=center;fontSize=11;verticalAlign=middle;" vertex="1"><mxGeometry x="80" y="800" width="420" height="80" as="geometry" /></mxCell><mxCell id="18" parent="1" value="&lt;b&gt;Decoding &amp; Routing Flow Logic:&lt;/b&gt;&lt;br/&gt;1. Sort batches globally by (priority, seq_gene).&lt;br/&gt;2. For each batch, process sequentially from Stage 0 to M-1.&lt;br/&gt;3. Machine assignment at stage w is selected by:&lt;br/&gt;   &lt;i&gt;Machine ID = ceil(mach_gene * eligible_machines) - 1&lt;/i&gt;&lt;br/&gt;4. Calculate start time at stage w:&lt;br/&gt;   &lt;i&gt;S_w = max(Machine_Free_Time, Ready_Time) + Setup_Time&lt;/i&gt;&lt;br/&gt;   Where &lt;i&gt;Ready_Time&lt;/i&gt; is:&lt;br/&gt;   • Stage 0: Material arrival time s_j&lt;br/&gt;   • Stage w &amp;gt; 0: End_time(w-1) + Transport_Time(w-1)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#D97706;strokeWidth=1.5;align=left;spacingLeft=8;fontSize=10;verticalAlign=top;spacingTop=4;" vertex="1"><mxGeometry x="80" y="900" width="420" height="130" as="geometry" /></mxCell><mxCell id="30" parent="1" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#4A5568;strokeWidth=2;align=center;fontStyle=1;" vertex="1"><mxGeometry x="780" y="130" width="100" height="40" as="geometry" /></mxCell><mxCell id="31" parent="1" value="Batch Splitting Preprocessing&lt;br/&gt;(Split Jobs where Total PT &amp;gt; T_threshold)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=2;align=center;" vertex="1"><mxGeometry x="700" y="200" width="260" height="50" as="geometry" /></mxCell><mxCell id="200" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="30" target="31" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="32" parent="1" value="Initialize GA Population&lt;br/&gt;(Size: 100, chromosome in [0, 1]^2N)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#2196F3;strokeWidth=2;align=center;" vertex="1"><mxGeometry x="700" y="280" width="260" height="45" as="geometry" /></mxCell><mxCell id="201" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="31" target="32" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="33" parent="1" value="Chromosome Decoder&lt;br/&gt;(List scheduling, Setup costs/times, Transit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;align=center;fontStyle=1;" vertex="1"><mxGeometry x="700" y="355" width="260" height="45" as="geometry" /></mxCell><mxCell id="202" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="32" target="33" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="34" parent="1" value="Evaluate Fitness&lt;br/&gt;(Minimize Total Tardiness &amp; Setup Costs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;align=center;" vertex="1"><mxGeometry x="700" y="430" width="260" height="45" as="geometry" /></mxCell><mxCell id="203" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="33" target="34" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="35" parent="1" value="Stall Limit reached?&lt;br/&gt;(No improvement for 100 gens)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FBC02D;strokeWidth=2;align=center;fontSize=10;" vertex="1"><mxGeometry x="730" y="500" width="200" height="70" as="geometry" /></mxCell><mxCell id="204" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="34" target="35" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="36" parent="1" value="Tabu Search local optimizer&lt;br/&gt;(Swap/Insert on best individual,&lt;br/&gt;Tabu list &amp; Aspiration criteria)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2F2;strokeColor=#EF5350;strokeWidth=2;align=center;fontStyle=1;" vertex="1"><mxGeometry x="700" y="600" width="260" height="60" as="geometry" /></mxCell><mxCell id="205" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="35" target="36" value="YES"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="206" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#4A5568;strokeWidth=1.5;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="35" target="37" value="NO"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="37" parent="1" value="Fuzzy Logic Controller (FLC)&lt;br/&gt;(Inputs: CV of Fitness &amp; Improvement Speed)&lt;br/&gt;(Outputs: Pc and Pm adjustments)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;align=center;fontStyle=1;" vertex="1"><mxGeometry x="700" y="690" width="260" height="65" as="geometry" /></mxCell><mxCell id="207" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="36" target="37" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="38" parent="1" value="Genetic Operators&lt;br/&gt;(Tournament Selection, Uniform Crossover, Mutate)&lt;br/&gt;(Elitism: 10% clones preserved)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#2196F3;strokeWidth=2;align=center;" vertex="1"><mxGeometry x="700" y="780" width="260" height="50" as="geometry" /></mxCell><mxCell id="208" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="37" target="38" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="39" parent="1" value="Termination Check&lt;br/&gt;(1000 generations or 10 min)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#FBC02D;strokeWidth=2;align=center;fontSize=10;" vertex="1"><mxGeometry x="730" y="860" width="200" height="60" as="geometry" /></mxCell><mxCell id="209" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="38" target="39" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="40" parent="1" value="Export Schedule &amp; KPIs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#4A5568;strokeWidth=2;align=center;" vertex="1"><mxGeometry x="700" y="950" width="260" height="45" as="geometry" /></mxCell><mxCell id="210" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="39" target="40" value="YES"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="41" parent="1" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#E2E8F0;strokeColor=#4A5568;strokeWidth=2;align=center;fontStyle=1;" vertex="1"><mxGeometry x="780" y="1020" width="100" height="40" as="geometry" /></mxCell><mxCell id="211" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="40" target="41" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="212" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2196F3;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=1;entryY=0.5;strokeDasharray=4;" edge="1" source="39" target="33" value="NO (Next Generation)"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="50" parent="1" value="Dataset Selector Panel&lt;br/&gt;(Scans refs/ Problems/*.mat, prints metadata)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF5;strokeColor=#D97706;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1160" y="150" width="410" height="60" as="geometry" /></mxCell><mxCell id="51" parent="1" value="SMT &amp; GA Parameter Settings&lt;br/&gt;(Workstation count, transport, Pc/Pm, TS iterations)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF5;strokeColor=#D97706;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1160" y="240" width="410" height="60" as="geometry" /></mxCell><mxCell id="52" parent="1" value="Optimization Process Workspace&lt;br/&gt;(Live plots: Fitness curves, diversity, FLC tracking)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F4F6;strokeColor=#4B5563;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1160" y="340" width="410" height="70" as="geometry" /></mxCell><mxCell id="300" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="50" target="52" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="301" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="51" target="52" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="53" parent="1" value="Plotly Interactive Gantt Canvas&lt;br/&gt;• Y-axis: Workstation Group &amp;gt; Machine ID&lt;br/&gt;• X-axis: Timeline (min)&lt;br/&gt;• Hover tooltips show quantities, priority, tardiness&lt;br/&gt;• Click/Filter/Zoom, Highlight same-job batches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;strokeWidth=2;align=left;spacingLeft=10;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1"><mxGeometry x="1160" y="450" width="410" height="100" as="geometry" /></mxCell><mxCell id="302" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="52" target="53" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="54" parent="1" value="Explainable Optimization Panel&lt;br/&gt;• Bottleneck identification (highest machine queue)&lt;br/&gt;• Analysis of critical tardy jobs (reason for delay)&lt;br/&gt;• Changeover &amp; setup cost overhead summary&lt;br/&gt;• Batch splitting efficiency explanation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;strokeWidth=2;align=left;spacingLeft=10;fontSize=10;verticalAlign=top;spacingTop=6;" vertex="1"><mxGeometry x="1160" y="580" width="410" height="100" as="geometry" /></mxCell><mxCell id="303" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="53" target="54" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="55" parent="1" value="CSV / Excel / JSON Schedule Exporter&lt;br/&gt;(Includes batch and job IDs, start/ends, setup, cost)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1160" y="710" width="410" height="60" as="geometry" /></mxCell><mxCell id="304" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#4A5568;strokeWidth=1.5;fontColor=#4A5568;fontSize=10;" edge="1" source="54" target="55" value=""><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="400" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#10B981;strokeWidth=2;strokeDasharray=3;" edge="1" source="40" target="52" value="Pass optimized schedule to dashboard"><mxGeometry relative="1" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>