        <mxCell id="title_block" parent="1" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" value="&lt;b&gt;&lt;font size='6' color='#1E3A8A'&gt;HYBRID OPTIMIZATION PROCESS (MEMETIC ALGORITHM)&lt;/font&gt;&lt;/b&gt;&lt;br/&gt;&lt;b&gt;&lt;font size='4' color='#475569'&gt;Step-by-Step Chromosome Refinement combining GA Exploration and Tabu Search Exploitation&lt;/font&gt;&lt;/b&gt;" vertex="1">
